# =============================================
# FluxMetric SaaS — Environment Variables
# Copie este arquivo para .env.local e preencha
# =============================================

# --- SUPABASE ---
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# Apenas no servidor / Edge Functions (nunca no frontend!)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# --- APIFY ---
APIFY_API_TOKEN=sua_apify_token
APIFY_ACTOR_ID=seu_actor_id

# --- STRIPE ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_PRICE_ID=price_xxxx

# --- APP ---
VITE_APP_URL=http://localhost:8080
